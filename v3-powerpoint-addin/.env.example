# Copie este arquivo para `.env.local` e cole a sua chave do Google AI Studio.
# NUNCA comite a chave real. `.env.local` é ignorado pelo git e pela Vercel.
# Para produção: `vercel env add GEMINI_API_KEY` (ou painel da Vercel).

GEMINI_API_KEY=cole-sua-chave-aqui

# Opcionais — só se precisar corrigir os IDs dos modelos sem mexer no código:
# GEMINI_MODEL_NANO2=gemini-3.1-flash-image
# GEMINI_MODEL_PRO=gemini-3-pro-image
# GEMINI_MODEL_TEXT=gemini-2.5-flash
